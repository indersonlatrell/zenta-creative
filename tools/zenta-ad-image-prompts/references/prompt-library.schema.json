{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zentacreative.com/schemas/ad-image-prompt-library-1.0.0.json",
  "title": "Zenta Ad Image Prompt Library",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "library_id",
    "brand",
    "created_at",
    "status",
    "assumptions",
    "prompts"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "library_id": { "type": "string", "minLength": 6 },
    "brand": { "const": "Zenta Creative" },
    "created_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["draft_for_human_review", "approved_for_generation"] },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/prompt" }
    }
  },
  "$defs": {
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_id",
        "content_type",
        "campaign",
        "creative_strategy",
        "format",
        "visual_direction",
        "copy",
        "generation_prompt",
        "negative_constraints",
        "accessibility",
        "compliance",
        "production"
      ],
      "properties": {
        "prompt_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "content_type": { "enum": ["paid_ad_image", "organic_image_post"] },
        "campaign": {
          "type": "object",
          "additionalProperties": false,
          "required": ["objective", "conversion", "service_id", "audience", "funnel_stage", "platforms", "placements", "geography", "language"],
          "properties": {
            "objective": { "type": "string", "minLength": 2 },
            "conversion": { "type": "string", "minLength": 2 },
            "service_id": { "type": "string", "minLength": 2 },
            "audience": { "type": "string", "minLength": 8 },
            "funnel_stage": { "enum": ["awareness", "consideration", "conversion", "retention"] },
            "platforms": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "placements": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "geography": { "type": "string", "minLength": 2 },
            "language": { "type": "string", "minLength": 2 }
          }
        },
        "creative_strategy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["concept_name", "audience_insight", "message_angle", "framework", "hook", "hypothesis"],
          "properties": {
            "concept_name": { "type": "string", "minLength": 3 },
            "audience_insight": { "type": "string", "minLength": 10 },
            "message_angle": { "type": "string", "minLength": 5 },
            "framework": { "type": "string", "minLength": 2 },
            "hook": { "type": "string", "minLength": 3 },
            "hypothesis": { "type": "string", "minLength": 12 }
          }
        },
        "format": {
          "type": "object",
          "additionalProperties": false,
          "required": ["aspect_ratio", "orientation", "spec_status", "crop_guidance"],
          "properties": {
            "aspect_ratio": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
            "orientation": { "enum": ["square", "portrait", "landscape"] },
            "spec_status": { "enum": ["verified_current", "needs_platform_preview", "organic_only"] },
            "crop_guidance": { "type": "string", "minLength": 8 }
          }
        },
        "visual_direction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["subject", "action", "environment", "composition", "lighting", "palette", "style"],
          "properties": {
            "subject": { "type": "string", "minLength": 3 },
            "action": { "type": "string", "minLength": 3 },
            "environment": { "type": "string", "minLength": 3 },
            "composition": { "type": "string", "minLength": 10 },
            "lighting": { "type": "string", "minLength": 3 },
            "palette": { "type": "array", "minItems": 2, "items": { "type": "string" } },
            "style": { "type": "string", "minLength": 8 }
          }
        },
        "copy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["overlay_headline", "overlay_support", "cta", "caption"],
          "properties": {
            "overlay_headline": { "type": "string", "minLength": 2 },
            "overlay_support": { "type": "string" },
            "cta": { "type": "string", "minLength": 2 },
            "caption": { "type": "string", "minLength": 20 }
          }
        },
        "generation_prompt": { "type": "string", "minLength": 120 },
        "negative_constraints": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 2 } },
        "accessibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["alt_text", "contrast_note"],
          "properties": {
            "alt_text": { "type": "string", "minLength": 10 },
            "contrast_note": { "type": "string", "minLength": 8 }
          }
        },
        "compliance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["claim_risk", "required_review"],
          "properties": {
            "claim_risk": { "enum": ["low", "medium", "high"] },
            "required_review": { "type": "array", "minItems": 1, "items": { "type": "string" } }
          }
        },
        "production": {
          "type": "object",
          "additionalProperties": false,
          "required": ["render_text_in_image", "logo_instruction", "human_review_required", "generation_status"],
          "properties": {
            "render_text_in_image": { "type": "boolean" },
            "logo_instruction": { "type": "string", "minLength": 5 },
            "human_review_required": { "const": true },
            "generation_status": { "enum": ["not_generated", "draft_generated", "approved"] }
          }
        }
      }
    }
  }
}
